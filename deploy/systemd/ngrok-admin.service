[Unit]
Description=ngrok admin panel
Documentation=file:/usr/local/share/doc/ngrok/SELFHOSTING.md
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
ExecStart=/usr/local/bin/ngrok-admin -addr=127.0.0.1:9090
Restart=on-failure
RestartSec=3s
PrivateTmp=true

[Install]
WantedBy=multi-user.target
