# Copy to /etc/ngrok/ngrokd.env and adjust for your deployment.
NGROKD_DOMAIN=example.com
NGROKD_TLS_CRT=/etc/ngrok/tls/example.com.crt
NGROKD_TLS_KEY=/etc/ngrok/tls/example.com.key
NGROKD_AUTH_TOKEN=change-me-long-random-token

# Use loopback public listeners when Nginx owns :80 and :443.
NGROKD_HTTP_ADDR=127.0.0.1:8080
NGROKD_HTTPS_ADDR=127.0.0.1:8443
NGROKD_TUNNEL_ADDR=0.0.0.0:4443

NGROKD_LOG_LEVEL=INFO
NGROKD_MAX_CONNECTIONS=1024

# Optional flags, for example:
#   -domainCert=example.net:/etc/ngrok/tls/example.net.crt:/etc/ngrok/tls/example.net.key
#   -allowRemotePorts=true
NGROKD_EXTRA_ARGS=
